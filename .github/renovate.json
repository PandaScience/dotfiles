{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchManagers": ["mise"],
      "groupName": "mise tools",
      "minimumReleaseAge": "14 days",
      "schedule": ["every 2 weeks on monday"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "prTitle": "tools: bump mise tool versions",
      "commitMessagePrefix": "tools:",
      "commitMessageAction": "bump",
      "commitMessageTopic": "mise tool versions"
    }
  ]
}
